# Local PostgreSQL (replace user/password with your real credentials):
# DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/menu_to_table?schema=public"

# Or use a hosted Postgres (Neon, Supabase, Render, etc.):
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Session signing secret (generate with: openssl rand -base64 32)
AUTH_SECRET="your-secret-key-here"

# Google Maps (Browse Chefs map panel + location autocomplete)
# 1. Create an API key at https://console.cloud.google.com/google/maps-apis/credentials
#    Valid keys always start with: AIzaSy
# 2. Enable APIs: Maps JavaScript API + Places API (New)
# 3. Create a Map ID at Map Management (not DEMO_MAP_ID)
# 4. Under key restrictions → HTTP referrers, add:
#    http://localhost:3000/*
#    http://127.0.0.1:3000/*
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=""

# Firebase (optional — separate from Google Maps API key)
# 1. firebase login && npm run firebase:use   (links .firebaserc project)
# 2. Firebase console → Project settings → Your apps → Web app config
# 3. Enable Firestore Database + Storage in the Firebase console
# 4. npm run firebase:deploy:rules            (deploy firestore.rules + storage.rules)
# 5. npm run firebase:emulators               (local Firestore/Storage on ports 8080/9199)
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# Firebase App Check (reCAPTCHA Enterprise)
# Firebase console → App Check → Register app → reCAPTCHA Enterprise
# For Google Maps: also register Maps JavaScript API in App Check
# Google Cloud → Security → reCAPTCHA Enterprise → create site key (score-based)
NEXT_PUBLIC_RECAPTCHA_ENTERPRISE_SITE_KEY=""
# Local dev only: set to "true" or a debug token from Firebase App Check console
NEXT_PUBLIC_FIREBASE_APPCHECK_DEBUG_TOKEN=""
