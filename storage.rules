rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Chef menu images, avatars, etc. — tighten paths before production.
    match /chefs/{chefId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == chefId;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
